PORT=3000
CORS_ORIGINS=http://localhost:4200,https://ondary.netlify.app

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=ondary_api
# Vercel/domain panel sometimes labels this as DB_NAME.
# DB_NAME=ondary_api

DB_SYNCHRONIZE=false
DB_LOGGING=false

JWT_SECRET=change-me
JWT_EXPIRES_IN=1d

# File installer Electron yang akan didownload frontend.
# Default: storage/desktop/ondary-desktop-installer.exe
DESKTOP_INSTALLER_PATH=storage/desktop/ondary-desktop-installer.exe
